# Gemini 2.5 — get from aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Your Ethereum wallet private key (starts with 0x)
# This wallet needs Sepolia ETH — get free from sepoliafaucet.com
RARE_PRIVATE_KEY=0xYourPrivateKeyHere

# Sepolia RPC — free from alchemy.com or infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key_here

# Set AFTER running: npm run deploy:collection
RARE_CONTRACT_ADDRESS=

# Your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
